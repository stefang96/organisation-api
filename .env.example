# Copy to `.env` and fill in the values. Do NOT commit your real .env.

# HTTP server
SERVER_PORT=5000

# Public base URL of THIS API (used in verification emails and static file
# links). Falls back to http://localhost:${SERVER_PORT} when unset.
API_BASE_URL=http://localhost:5000

# Allowed CORS origin. Use a concrete origin in production; "*" allows any.
CORS_ORIGIN=*

# Frontend base URL (used for the set-password redirect).
FRONTEND_URL=http://localhost:3000

# PostgreSQL connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DATABASE=organisation

# Auth
TOKEN_SECRET_KEY=change-me
TOKEN_EXP_TIME=24h

# Uploads: directory served under /static
PUBLIC_FOLDER=public

# Nodemailer (Gmail) credentials for outgoing mail
NODEMAILER_USER=
NODEMAILER_PASSWORD=
